{
  "folders": [
    {
      "name": "mastra",
      "path": "."
    },
    {
      "name": "bff",
      "path": "bff"
    },
    {
      "name": "frontend",
      "path": "frontend"
    },
    {
      "name": "langgraph",
      "path": "../my-first-agent-langgraph"
    }
  ],
  "settings": {
    "files.exclude": {
      "bff": true,
      "frontend": true
    },
    "search.exclude": {
      "bff": true,
      "frontend": true
    },
    "powershell.cwd": "mastra"
  },
  "launch": {
    "version": "0.2.0",
    "configurations": [
      {
        "type": "node",
        "request": "launch",
        "name": "Debug Mastra CLI",
        "cwd": "${workspaceFolder:mastra}",
        "program": "${workspaceFolder:mastra}/node_modules/mastra/dist/index.js",
        "args": [
          "dev"
        ],
        "console": "integratedTerminal",
        "autoAttachChildProcesses": true,
        "restart": true,
        "skipFiles": [
          "<node_internals>/**"
        ]
      },
      {
        "type": "debugpy",
        "request": "launch",
        "name": "Debug Python Agent",
        "cwd": "${workspaceFolder:langgraph}",
        "module": "uvicorn",
        "args": [
          "app.main:app",
          "--host",
          "0.0.0.0",
          "--port",
          "8011"
        ],
        "env": {
          "PYTHONPATH": "src"
        },
        "console": "integratedTerminal"
      },
      {
        "type": "node",
        "request": "launch",
        "name": "Debug BFF",
        "cwd": "${workspaceFolder:bff}",
        "runtimeExecutable": "node",
        "program": "${workspaceFolder:bff}/node_modules/ts-node/dist/bin.js",
        "args": [
          "--project",
          "${workspaceFolder:bff}/tsconfig.json",
          "src/main.ts"
        ],
        "env": {
          "AGENT_RUNTIME_PROVIDER": "python",
          "PY_AGENT_BASE_URL": "http://localhost:8011"
        },
        "console": "integratedTerminal",
        "skipFiles": [
          "<node_internals>/**"
        ],
        "sourceMaps": true,
        "resolveSourceMapLocations": [
          "${workspaceFolder:bff}/**",
          "!**/node_modules/**"
        ]
      },
      {
        "type": "node",
        "request": "launch",
        "name": "Debug BFF (Mastra)",
        "cwd": "${workspaceFolder:bff}",
        "runtimeExecutable": "node",
        "program": "${workspaceFolder:bff}/node_modules/ts-node/dist/bin.js",
        "args": [
          "--project",
          "${workspaceFolder:bff}/tsconfig.json",
          "src/main.ts"
        ],
        "env": {
          "AGENT_RUNTIME_PROVIDER": "mastra",
          "MASTRA_BASE_URL": "http://localhost:4111"
        },
        "console": "integratedTerminal",
        "skipFiles": [
          "<node_internals>/**"
        ],
        "sourceMaps": true,
        "resolveSourceMapLocations": [
          "${workspaceFolder:bff}/**",
          "!**/node_modules/**"
        ]
      },
      {
        "type": "node",
        "request": "launch",
        "name": "Debug Mastra Runtime Output",
        "cwd": "${workspaceFolder:mastra}",
        "runtimeExecutable": "node",
        "program": "${workspaceFolder:mastra}/.mastra/output/index.mjs",
        "console": "integratedTerminal",
        "skipFiles": [
          "<node_internals>/**"
        ]
      },
      {
        "type": "node",
        "request": "launch",
        "name": "Debug Frontend",
        "cwd": "${workspaceFolder:frontend}",
        "runtimeExecutable": "npm.cmd",
        "runtimeArgs": [
          "run",
          "dev",
          "--",
          "--host",
          "127.0.0.1",
          "--port",
          "4173"
        ],
        "console": "integratedTerminal",
        "serverReadyAction": {
          "pattern": "(http://127\\.0\\.0\\.1:4173/?|http://localhost:4173/?)",
          "action": "startDebugging",
          "name": "Open Frontend Chrome"
        },
        "skipFiles": [
          "<node_internals>/**"
        ]
      },
      {
        "type": "chrome",
        "request": "launch",
        "name": "Open Frontend Chrome",
        "url": "http://127.0.0.1:4173",
        "webRoot": "${workspaceFolder:frontend}",
        "sourceMaps": true
      }
    ],
    "compounds": [
      {
        "name": "Debug All Repos",
        "configurations": [
          "Debug Python Agent",
          "Debug BFF",
          "Debug Frontend"
        ],
        "stopAll": true
      },
      {
        "name": "Debug Backends",
        "configurations": [
          "Debug Python Agent",
          "Debug BFF"
        ],
        "stopAll": true
      },
      {
        "name": "Debug All Repos (Mastra)",
        "configurations": [
          "Debug Mastra CLI",
          "Debug BFF (Mastra)",
          "Debug Frontend"
        ],
        "stopAll": true
      },
      {
        "name": "Debug Backends (Mastra)",
        "configurations": [
          "Debug Mastra CLI",
          "Debug BFF (Mastra)"
        ],
        "stopAll": true
      }
    ]
  }
}
