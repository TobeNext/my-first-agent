{
  "name": "my-first-agent",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:workspace",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run test:e2e:interview",
    "test:e2e:interview:smoke": "node scripts/run-interview-e2e-provider.mjs smoke python",
    "test:e2e:interview:smoke:python": "node scripts/run-interview-e2e-provider.mjs smoke python",
    "test:e2e:interview:smoke:mastra": "node scripts/run-interview-e2e-provider.mjs smoke mastra",
    "test:e2e:interview:complete:python": "node scripts/run-interview-e2e-provider.mjs complete python",
    "test:e2e:interview:complete:mastra": "node scripts/run-interview-e2e-provider.mjs complete mastra",
    "test:e2e:interview:python": "node scripts/run-interview-e2e-provider.mjs all python",
    "test:e2e:interview:mastra": "node scripts/run-interview-e2e-provider.mjs all mastra",
    "test:e2e:interview:rollback-smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/run-provider-rollback-smoke.ps1",
    "test:e2e:interview": "node scripts/run-interview-e2e-provider.mjs all python",
    "test:workspace": "npm run test:coverage && npm --prefix bff run test:coverage && npm --prefix frontend run test:coverage",
    "dev": "npm run start:local",
    "dev:mastra": "mastra dev",
    "build": "mastra build",
    "start": "npm run start:local",
    "start:mastra": "mastra start",
    "worker:answer-evaluation": "tsx src/mastra/scripts/run-answer-evaluation-worker.ts",
    "migrate:vectors:milvus": "tsx src/mastra/scripts/migrate-libsql-vectors-to-milvus.ts --recreate",
    "backfill:vectors:milvus-metadata": "tsx src/mastra/scripts/backfill-milvus-interview-question-metadata.ts",
    "start:local": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local.ps1",
    "start:local:mastra": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local.ps1 -AgentRuntimeProvider mastra",
    "start:all": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local.ps1 -StartDockerDependencies",
    "start:all:mastra": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local.ps1 -StartDockerDependencies -AgentRuntimeProvider mastra"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@mastra/core": "^1.10.0",
    "@mastra/fastembed": "^1.0.1",
    "@mastra/libsql": "^1.6.4",
    "@mastra/loggers": "^1.0.2",
    "@mastra/memory": "^1.6.1",
    "@mastra/observability": "^1.3.1",
    "@mastra/rag": "^2.2.0",
    "@zilliz/milvus2-sdk-node": "^3.0.1",
    "ai": "^6.0.161",
    "redis": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^3.2.4",
    "mastra": "^1.7.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
