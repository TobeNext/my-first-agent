OPENAI_API_KEY=your-api-key
# ZHIPU_API_KEY=your-zhipu-api-key

# Python LangGraph model provider. Keep mock for no-key local startup.
MODEL_PROVIDER=mock
MODEL_NAME=mock/interview-runtime
# MODEL_API_KEY=
# MODEL_BASE_URL=
# MODEL_TIMEOUT_SECONDS=20
# MODEL_MAX_RETRIES=2
# MODEL_TEMPERATURE=0.2

# Python LangGraph embedding provider. Keep hash for no-key local startup.
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=384
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=

# Agent runtime cutover
AGENT_RUNTIME_PROVIDER=python
MASTRA_BASE_URL=http://localhost:4111
PY_AGENT_BASE_URL=http://localhost:8011

# Milvus vector store
MILVUS_ADDRESS=localhost:19530
# MILVUS_USERNAME=
# MILVUS_PASSWORD=
# MILVUS_TOKEN=
# MILVUS_DATABASE=default
# MILVUS_SSL=false

# Source LibSQL vector DB used only by the migration script
LIBSQL_VECTOR_DB_URL=file:./interview-vectors.db

# Redis service used by async answer evaluation tasks
REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_SECONDS=0.2
REDIS_SOCKET_TIMEOUT_SECONDS=0.2

# OpenTelemetry
OTEL_SERVICE_NAME=interview-bff
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_TRACES_SAMPLER=always_on
OTEL_TRACES_SAMPLER_ARG=1
OTEL_PROPAGATORS=tracecontext,baggage
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# LangSmith, only used by Python LangGraph runtime
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=my-first-agent-local
# Informational metadata only; LangSmith tracing is enabled by LANGSMITH_TRACING + key.
LANGSMITH_DATA_MODE=standard
